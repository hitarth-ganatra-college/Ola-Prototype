# Google Maps API key — get yours at https://console.cloud.google.com/
# Enable "Maps JavaScript API" and restrict to your domain.
VITE_GOOGLE_MAPS_API_KEY=YOUR_KEY_HERE

# Optional: override backend URLs (defaults via Vite proxy to localhost)
# VITE_IDENTITY_URL=http://localhost:4001
# VITE_MATCHING_URL=http://localhost:4004
# VITE_TRIP_URL=http://localhost:4005
# VITE_TRACKING_URL=http://localhost:4003
# VITE_ADMIN_URL=http://localhost:4002

# Optional: realtime gateway (leave blank to use mock adapter)
# VITE_WS_URL=ws://localhost:4006
# VITE_SSE_URL=http://localhost:4006/events
